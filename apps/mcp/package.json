{
  "name": "@nota-app/mcp",
  "version": "0.1.0",
  "private": false,
  "description": "Nota MCP server for Claude Desktop, Claude Code, Cursor, and other MCP clients.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelfahle/nota.git",
    "directory": "apps/mcp"
  },
  "homepage": "https://github.com/marcelfahle/nota/tree/main/apps/mcp",
  "keywords": [
    "nota",
    "mcp",
    "model-context-protocol",
    "invoicing",
    "claude"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "nota-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run --cwd ../../packages/sdk build && bun run src/index.ts",
    "build": "bun run --cwd ../../packages/sdk build && rm -rf dist && tsc -p tsconfig.json && chmod +x dist/index.js",
    "check": "bun run --cwd ../../packages/sdk build && tsc --noEmit",
    "test": "bun run build && bun test tests",
    "prepublishOnly": "bun run test"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6",
    "@nota-app/sdk": "workspace:*"
  }
}
