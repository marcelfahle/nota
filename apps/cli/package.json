{
  "name": "@nota-app/cli",
  "version": "0.1.0",
  "private": false,
  "description": "Command-line interface for Nota.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelfahle/nota.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/marcelfahle/nota/tree/main/apps/cli",
  "keywords": [
    "nota",
    "cli",
    "invoicing",
    "billing"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "nota": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run --cwd ../../packages/sdk build && rm -rf dist && tsc -p tsconfig.json && chmod +x dist/index.js",
    "check": "bun run --cwd ../../packages/sdk build && tsc --noEmit",
    "prepublishOnly": "bun run build && bun run check",
    "test": "bun test tests"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.1",
    "@nota-app/sdk": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
